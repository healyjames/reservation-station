# Local development environment variables.
# Copy this file to .env and fill in real values.
# .env is gitignored — never commit secrets.

# Enables localhost CORS origins and other dev-only behaviour.
# Leave as "development" for local dev; wrangler.jsonc defaults to "production" for deploys.
ENVIRONMENT=development

# Public-facing URL used in email links (cancel / manage booking).
# For local dev this is the Vite dev server. For production, set in the Cloudflare dashboard.
PUBLIC_URL=http://localhost:5173

# Secret used to sign JWTs for admin authentication.
# Generate with: openssl rand -hex 32
JWT_SECRET=

# Resend API key for transactional email.
# Get from https://resend.com/api-keys
RESEND_API_KEY=

# Secret key for super-admin tenant management endpoints (X-Admin-Key header).
# Generate with: openssl rand -hex 32
SUPER_ADMIN_KEY=
